# Copy to .env and fill in. Never commit the real .env.
# These are the local-fallback values; the cloud run reads the same names
# from GitHub Actions repo secrets (see .github/workflows/daily.yml).

APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# Summarizer (Anthropic Messages API). The cloud run has no Claude CLI login,
# so summarization uses a direct API call. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# Curated Twitter List (recommended; one cheap Apify call, even distribution)
TWITTER_LIST_ID=0000000000000000000

# Telegram delivery
TELEGRAM_BOT_TOKEN=0000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=000000000

# Optional overrides
# WINDOW_HOURS=24
# MAX_ITEMS=200
